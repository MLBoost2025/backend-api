# ------------------------------------------------------------------
# Katalume backend-api environment configuration
# Copy to .env and fill in real values. NEVER commit the real .env.
# ------------------------------------------------------------------

# App
NODE_ENV=development
BACKEND_PORT=5001
# Number of trusted reverse proxies in front of Express (0 for direct local traffic).
TRUST_PROXY=0

# Database
MONGO_URI=mongodb://localhost:27017/katalume
MONGO_POOL_SIZE=20

# JWT secrets — REQUIRED in production (server refuses to start without them).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Session cookie. Leave COOKIE_DOMAIN blank for localhost. In production, use a shared
# parent domain (for example .katalume.com) so the frontend middleware receives it.
COOKIE_DOMAIN=
# Use none only for HTTPS cross-site API deployments; secure is enabled automatically.
COOKIE_SAME_SITE=strict
# Keep false in production; browser authentication is cookie-only.
ALLOW_BEARER_AUTH=false

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Judge0 code-execution service
JUDGE0_URL=http://localhost:2358
# Must match AUTHN_TOKEN in judge0.conf; leave blank only for a trusted local setup.
JUDGE0_AUTH_TOKEN=
# Hard request/poll deadline and maximum concurrent testcase executions per job.
JUDGE0_TIMEOUT_MS=20000
JUDGE0_POLL_INTERVAL_MS=250
JUDGE0_CONCURRENCY=4

# Execution guards
# Comma-separated Judge0 language IDs permitted for execution.
ALLOWED_LANGUAGE_IDS=50,51,54,60,62,63,68,71,72,73,74
# Maximum source-code size in bytes.
MAX_CODE_SIZE=65536

# Durable evaluation worker. Run `npm run worker` as a separate service.
EVALUATION_WORKER_POLL_MS=500
EVALUATION_JOB_MAX_ATTEMPTS=3
EVALUATION_JOB_RETENTION_DAYS=7

# Redis (distributed API/auth/execution rate limits; jobs are durable in MongoDB)
# Required in production for distributed API/execution rate limits.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# --- OAuth / social login (optional) ---
# A provider activates ONLY when both its id and secret are set; otherwise it is
# simply hidden. Create the apps in the Google Cloud Console and GitHub Developer
# settings, using {OAUTH_CALLBACK_BASE_URL}/api/auth/oauth/{provider}/callback as
# the authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Public base URL of THIS backend (the API subdomain in production),
# e.g. https://api.katalume.com  — used to build the OAuth redirect URI.
OAUTH_CALLBACK_BASE_URL=http://localhost:5001
# Web app origin the browser is sent back to after a social login completes.
FRONTEND_URL=http://localhost:3000

# --- Content pipeline (ml-problems repo) ---
# Service token authorizing POST /api/import/problems (the ml-problems sync
# workflow). Endpoint is disabled until set. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
PROBLEMS_IMPORT_TOKEN=
