# Copy to api.env on the API host. Keep api.env mode 0600 and never commit it.
NODE_ENV=production
EXECUTION_MODE=judge0
BACKEND_PORT=5001
TRUST_PROXY=1

MONGO_URI=mongodb+srv://katalume_app:REPLACE_ME@cluster.example.mongodb.net/katalume?retryWrites=true&w=majority&appName=Katalume
MONGO_POOL_SIZE=20
REDIS_URL=rediss://default:REPLACE_ME@redis.example:6379

JWT_ACCESS_SECRET=REPLACE_ME
JWT_REFRESH_SECRET=REPLACE_ME

CORS_ORIGIN=https://katalume.com,https://www.katalume.com
COOKIE_DOMAIN=.katalume.com
COOKIE_SAME_SITE=lax
ALLOW_BEARER_AUTH=false

JUDGE0_URL=http://10.0.0.3:2358
JUDGE0_AUTH_TOKEN=REPLACE_ME
JUDGE0_TIMEOUT_MS=20000
JUDGE0_POLL_INTERVAL_MS=250
JUDGE0_CONCURRENCY=4
ALLOWED_LANGUAGE_IDS=71
MAX_CODE_SIZE=65536

EVALUATION_WORKER_POLL_MS=500
EVALUATION_JOB_MAX_ATTEMPTS=3
EVALUATION_JOB_RETENTION_DAYS=7

GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GITHUB_CLIENT_ID=REPLACE_ME
GITHUB_CLIENT_SECRET=REPLACE_ME
OAUTH_CALLBACK_BASE_URL=https://api.katalume.com
FRONTEND_URL=https://katalume.com
